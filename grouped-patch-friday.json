{
  "description": "Prepare updates during weekends, automerge non-major updates on Mondays",
  "extends": [
    "config:best-practices",
    "helpers:pinGitHubActionDigestsToSemver",
    ":semanticCommits",
    "github>capralifecycle/renovate-config:group-minor"
  ],
  "timezone": "Europe/Oslo",

  "minimumReleaseAge": "3 days",

  "schedule": ["* * * * 0,6"],

  "platformAutomerge": false,

  "updateNotScheduled": true,

  "automergeSchedule": ["* 6-14 * * 1"],

  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": ["* * * * 0,6"]
  },
  "packageRules": [
    {
      "description": "Lock file maintenance PRs do not have releaseTimestamp",
      "matchUpdateTypes": [
        "lockFileMaintenance"
      ],
      "minimumReleaseAge": null
    }
  ]
}
